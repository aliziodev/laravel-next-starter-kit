APP_NAME="Laravel Next Starter Kit"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Database-backed sessions are required: the cookie/SPA flow (and the optional
# browser-sessions feature) read session records from the `sessions` table.
SESSION_DRIVER=database
SESSION_LIFETIME=120
# Pinned so the Next proxy's optimistic cookie check has a stable name
# regardless of APP_NAME.
SESSION_COOKIE=laravel_session
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# --- Decoupled Next.js frontend ---------------------------------------------
# Used for SPA redirects in emails (verification / password reset links point
# back to the Next.js app rather than the API).
FRONTEND_URL=http://localhost:3000
# Origins Sanctum treats as first-party (stateful/cookie auth). Must include:
#  - the frontend origin (:3000) — the browser's Referer reaches Laravel via the proxy;
#  - the API origin (:8000) — server-side getUser()/serverFetch() (SSR) send it as Origin.
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000,localhost:8000,127.0.0.1:8000

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Default to the `log` mailer (verification / reset links are written to
# storage/logs/laravel.log). To preview emails in a UI, run Mailpit and switch to:
#   MAIL_MAILER=smtp  MAIL_HOST=127.0.0.1  MAIL_PORT=1025
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
