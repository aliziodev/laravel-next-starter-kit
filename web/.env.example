# Client (browser) → same-origin proxy. The Next route handler at
# app/api/sanctum/[...path] forwards these requests to the Laravel API,
# so the browser only ever talks to the Next origin (no CORS).
NEXT_PUBLIC_SANCTUM_BASE_URL=/api/sanctum

# Server-only: the real Laravel API origin. Used as the route-proxy upstream
# and by getUser()/serverFetch() (server-to-server, which also send Origin so
# Sanctum's statefulApi() recognises the SSR request).
SANCTUM_BASE_URL=http://localhost:8000
